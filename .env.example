# Neon Postgres connection string (provisioned via Vercel Marketplace
# `neon-postgres` integration). Use the pooled connection URL.
DATABASE_URL="postgres://user:password@host/db?sslmode=require"

# Secret used to sign session JWTs (HS256). Must be a long, random string.
# Used by lib/auth.ts (createSession / getSession / clearSession).
SESSION_SECRET="replace-with-a-long-random-string"
